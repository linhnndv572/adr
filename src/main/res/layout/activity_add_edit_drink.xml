<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Th&#234;m &#273;&#7891; u&#7889;ng"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <!-- Form Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="24dp"
            android:layout_marginTop="24dp">

            <!-- Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="T&#234;n &#273;&#7891; u&#7889;ng"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#5E81AC"/>

            <EditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="VD: Tr&#224; &#272;&#224;o Cam S&#7843;"
                android:inputType="text"
                android:background="@drawable/bg_input_login"
                android:padding="14dp"
                android:textSize="14sp"
                android:textColor="#023E8A"
                android:textColorHint="#A0B0C0"
                android:layout_marginTop="6dp"
                android:maxLines="1"/>

            <!-- Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="M&#244; t&#7843;"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#5E81AC"
                android:layout_marginTop="14dp"/>

            <EditText
                android:id="@+id/et_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="VD: H&#432;&#417;ng v&#7883; tr&#224; th&#417;m ng&#225;t"
                android:inputType="text"
                android:background="@drawable/bg_input_login"
                android:padding="14dp"
                android:textSize="14sp"
                android:textColor="#023E8A"
                android:textColorHint="#A0B0C0"
                android:layout_marginTop="6dp"
                android:maxLines="1"/>

            <!-- Price -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gi&#225;"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#5E81AC"
                android:layout_marginTop="14dp"/>

            <EditText
                android:id="@+id/et_price"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="VD: 45.000&#273;"
                android:inputType="text"
                android:background="@drawable/bg_input_login"
                android:padding="14dp"
                android:textSize="14sp"
                android:textColor="#023E8A"
                android:textColorHint="#A0B0C0"
                android:layout_marginTop="6dp"
                android:maxLines="1"/>

            <!-- Emoji -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Emoji"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#5E81AC"
                android:layout_marginTop="14dp"/>

            <EditText
                android:id="@+id/et_emoji"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="VD: &#127825;"
                android:inputType="text"
                android:background="@drawable/bg_input_login"
                android:padding="14dp"
                android:textSize="14sp"
                android:textColor="#023E8A"
                android:textColorHint="#A0B0C0"
                android:layout_marginTop="6dp"
                android:maxLines="1"/>

            <!-- Category -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lo&#7841;i"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#5E81AC"
                android:layout_marginTop="14dp"/>

            <EditText
                android:id="@+id/et_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="VD: Tr&#224;, Sinh t&#7889;, N&#432;&#7899;c &#233;p..."
                android:inputType="text"
                android:background="@drawable/bg_input_login"
                android:padding="14dp"
                android:textSize="14sp"
                android:textColor="#023E8A"
                android:textColorHint="#A0B0C0"
                android:layout_marginTop="6dp"
                android:maxLines="1"/>

            <!-- Save Button -->
            <Button
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="L&#432;u"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#023E8A"
                android:background="@drawable/btn_gradient_yellow"
                android:layout_marginTop="24dp"
                android:stateListAnimator="@null"/>

            <!-- Cancel Button -->
            <TextView
                android:id="@+id/btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="H&#7911;y"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#0077B6"
                android:layout_marginTop="12dp"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
