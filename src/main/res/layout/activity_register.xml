<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <!-- ========== BRANDING ========== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☀️"
            android:textSize="48sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Summer Drinks"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tạo tài khoản mới"
            android:textSize="14sp"
            android:textColor="#B3FFFFFF"
            android:layout_marginTop="4dp"/>

        <!-- ========== REGISTER CARD ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="24dp"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đăng ký"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#023E8A"/>

            <!-- Full Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Họ và tên"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#5E81AC"
                android:layout_marginTop="18dp"/>

            <EditText
                android:id="@+id/et_fullname"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập họ và tên"
                android:inputType="textPersonName"
                android:background="@drawable/bg_input_login"
                android:padding="14dp"
                android:textSize="14sp"
                android:textColor="#023E8A"
                android:textColorHint="#A0B0C0"
                android:layout_marginTop="6dp"
                android:maxLines="1"/>

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#5E81AC"
                android:layout_marginTop="14dp"/>

            <EditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập email của bạn"
                android:inputType="textEmailAddress"
                android:background="@drawable/bg_input_login"
                android:padding="14dp"
                android:textSize="14sp"
                android:textColor="#023E8A"
                android:textColorHint="#A0B0C0"
                android:layout_marginTop="6dp"
                android:maxLines="1"/>

            <!-- Phone -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Số điện thoại"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#5E81AC"
                android:layout_marginTop="14dp"/>

            <EditText
                android:id="@+id/et_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập số điện thoại"
                android:inputType="phone"
                android:background="@drawable/bg_input_login"
                android:padding="14dp"
                android:textSize="14sp"
                android:textColor="#023E8A"
                android:textColorHint="#A0B0C0"
                android:layout_marginTop="6dp"
                android:maxLines="1"/>

            <!-- Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mật khẩu"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#5E81AC"
                android:layout_marginTop="14dp"/>

            <EditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập mật khẩu"
                android:inputType="textPassword"
                android:background="@drawable/bg_input_login"
                android:padding="14dp"
                android:textSize="14sp"
                android:textColor="#023E8A"
                android:textColorHint="#A0B0C0"
                android:layout_marginTop="6dp"
                android:maxLines="1"/>

            <!-- Confirm Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xác nhận mật khẩu"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#5E81AC"
                android:layout_marginTop="14dp"/>

            <EditText
                android:id="@+id/et_confirm_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập lại mật khẩu"
                android:inputType="textPassword"
                android:background="@drawable/bg_input_login"
                android:padding="14dp"
                android:textSize="14sp"
                android:textColor="#023E8A"
                android:textColorHint="#A0B0C0"
                android:layout_marginTop="6dp"
                android:maxLines="1"/>

            <!-- Terms -->
            <CheckBox
                android:id="@+id/cb_terms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tôi đồng ý với Điều khoản sử dụng"
                android:textSize="13sp"
                android:textColor="#5E81AC"
                android:layout_marginTop="16dp"/>

            <!-- Register Button -->
            <Button
                android:id="@+id/btn_register"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Đăng ký"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#023E8A"
                android:background="@drawable/btn_gradient_yellow"
                android:layout_marginTop="20dp"
                android:stateListAnimator="@null"/>

            <!-- Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E0E8F0"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  hoặc đăng ký với  "
                    android:textSize="13sp"
                    android:textColor="#A0B0C0"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E0E8F0"/>

            </LinearLayout>

            <!-- Social Register -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_social_circle">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="G"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#EA4335"
                        android:gravity="center"/>

                </FrameLayout>

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_social_circle"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="f"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#1877F2"
                        android:gravity="center"/>

                </FrameLayout>

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_social_circle"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="A"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:gravity="center"/>

                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ========== LOGIN LINK ========== -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đã có tài khoản? "
                android:textSize="14sp"
                android:textColor="#E0F7FA"/>

            <TextView
                android:id="@+id/tv_login_link"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đăng nhập"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFD166"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
